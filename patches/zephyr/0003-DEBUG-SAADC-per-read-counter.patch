From 1290bf69bafd0edd810f431589aa8a6124f38e8a Mon Sep 17 00:00:00 2001
From: Karel Tucek <kareltucek@centrum.cz>
Date: Wed, 10 Jun 2026 11:37:56 +0200
Subject: [PATCH] DEBUG: SAADC per-read counter

Temporary diagnostic: prints a per-read anchor line with the trigger
return value to correlate with the nrfx SAADC_DBG traces. Not for upstream.
---
 drivers/adc/adc_nrfx_saadc.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/drivers/adc/adc_nrfx_saadc.c b/drivers/adc/adc_nrfx_saadc.c
index 4e3979bc3f0..d04215c7f69 100644
--- a/drivers/adc/adc_nrfx_saadc.c
+++ b/drivers/adc/adc_nrfx_saadc.c
@@ -14,6 +14,7 @@
 #include <zephyr/pm/device_runtime.h>
 #include <dmm.h>
 #include <soc.h>
+#include <zephyr/sys/printk.h> /* DEBUG: SAADC hang instrumentation */
 
 LOG_MODULE_REGISTER(adc_nrfx_saadc, CONFIG_ADC_LOG_LEVEL);
 
@@ -282,6 +283,8 @@ static int adc_nrfx_channel_setup(const struct device *dev,
 	return 0;
 }
 
+static uint32_t saadc_dbg_read; /* DEBUG */
+
 static void adc_context_start_sampling(struct adc_context *ctx)
 {
 	if (ctx->sequence.calibrate) {
@@ -289,6 +292,7 @@ static void adc_context_start_sampling(struct adc_context *ctx)
 	} else {
 		int ret = nrfx_saadc_mode_trigger();
 
+		printk("SAADC ==== read #%u trigger ret=%d ====\n", ++saadc_dbg_read, ret); /* DEBUG */
 		if (ret != 0) {
 			LOG_ERR("Cannot start sampling: %d", ret);
 			adc_context_complete(ctx, -EIO);
-- 
2.51.0

